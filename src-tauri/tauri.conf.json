{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GoBirdie Desktop",
  "version": "2.0.2",
  "identifier": "com.chester.go-birdie-desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:9002"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "GoBirdie Desktop",
        "width": 1280,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "shell": {
      "open": "^https?://.*"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "src/native/garmin_mtp",
      "src/native/gobirdie-sync-helper"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ]
  }
}
